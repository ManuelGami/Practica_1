<robot name="robot" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <!--Propiedades-->
  <xacro:property name="length" value="0.3">
  <xacro:property name="width" value="0.05">
  <!--Macros-->
  <!--Eslabones-->
  <xacro:macro name="link_macro" params="name box origin">
    <link name="${name}">
    <visual>
      <geometry>
        <box size="${box}"/>
      </geometry>
      <origin xyz="${origin}"/>
      <material name="black">
        <color rgba="0 0 0 0.5"/>
      </material>
    </visual>
  </link>
  </xacro:macro>
  
  <!--Juntas-->
  <xacro:macro name="joint_macro" params="name type parent child rpy xyz">
  <joint name="${name}" type="${type}"> 
    <parent link="${parent}"/>
    <child link="${child}"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper ="3.14" effort="10.0" velocity="10.0"/>
    <origin rpy="${rpy}" xyz="${xyz}"/> 
  </joint>
  </xacro:macro>
  
  <!--Eslabones-->
  <xacro:link_macro name="base_link"      box="0.5 0.5 0.1"   origin="0 0 -0.05">
  <xacro:link_macro name="shoulder_link"  box="0.05 0.05 0.3" origin="0.15 0 0">
  <xacro:link_macro name="arm_link"       box="0.05 0.05 0.3" origin="0.15 0 0">
  <xacro:link_macro name="forearm_link"   box="0.05 0.05 0.3" origin="0.15 0 0">
  <!--Juntas-->
  <xacro:joint_macro name="" type="" parent="" child="" rpy="" xyz="">
  <xacro:joint_macro name="" type="" parent="" child="" rpy="" xyz="">
  <xacro:joint_macro name="" type="" parent="" child="" rpy="" xyz="">


  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.5 0.5 0.1"/>
      </geometry>
      <origin xyz="0 0 -0.05"/>
      <material name="black">
        <color rgba="0 0 0 0.5"/>
      </material>
    </visual>
  </link>

  <link name="shoulder_link">
    <visual>
      <geometry>
        <box size="0.3 0.05 0.05"/>
      </geometry>
      <origin xyz="0.15 0 0"/>
      <material name="cyan">
        <color rgba="0 1 1 1"/>
      </material>
    </visual>
  </link>
  <link name="arm_link">
    <visual>
      <geometry>
        <box size="0.3 0.05 0.05"/>
      </geometry>
      <origin xyz="0.15 0 0"/>
      <material name="magenta">
        <color rgba="1 0 1 1"/>
      </material>
    </visual>
  </link>
  <link name="forearm_link">
    <visual>
      <geometry>
        <box size="0.3 0.05 0.05"/>
      </geometry>
      <origin xyz="0.15 0 0"/>
      <material name="yellow">
        <color rgba="1 1 0 1"/>
      </material>
    </visual>
  </link>

  <!--Descripción de las juntas-->
  <joint name="shoulder_joint" type="revolute"> <!--tipo de junta: revolute, prismatic, fixed-->
    <parent link="base_link"/>
    <child link="shoulder_link"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper ="3.14" effort="10.0" velocity="10.0"/>
    <origin rpy="1.57 0 0" xyz="0 0 0"/> <!--roll, pitch, yaw-->
  </joint>
  <joint name="arm_joint" type="revolute"> <!--tipo de junta: revolute, prismatic, fixed-->
    <parent link="shoulder_link"/>
    <child link="arm_link"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper ="3.14" effort="10.0" velocity="10.0"/>
    <origin xyz="0.3 0 0" rpy="0 0 0"/>
  </joint>
  <joint name="forearm_joint" type="revolute"> <!--tipo de junta: revolute, prismatic, fixed-->
    <parent link="arm_link"/>
    <child link="forearm_link"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper ="3.14" effort="10.0" velocity="10.0"/>
    <origin xyz="0.3 0 0"/>
  </joint>
</robot>